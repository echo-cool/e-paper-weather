/* Wi-Fi credentials for esp32-weather-epd.
 *
 * Copy this file to "secrets.h" (in the same folder) and fill in your own
 * values. secrets.h is gitignored and must never be committed.
 *
 *   cp secrets.h.example secrets.h
 *
 * If secrets.h is absent, config.cpp falls back to placeholder values so the
 * project still compiles (e.g. in CI), but it will not connect to Wi-Fi.
 */
#ifndef SECRETS_H
#define SECRETS_H

#define SECRET_WIFI_SSID     "your-wifi-ssid"
#define SECRET_WIFI_PASSWORD "your-wifi-password"

#endif // SECRETS_H
